@using DotNetNuke.Web.DDRMenu;
@using System.Dynamic;
@using DotNetNuke.Common;
@using DotNetNuke.Entities.Portals;
@using DotNetNuke.Entities.Users;
@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>

@{
    var ps = PortalSettings.Current;
    var user = UserController.Instance.GetCurrentUserInfo();
    bool isAuth = HttpContext.Current.Request.IsAuthenticated;

    // Logo
    string logoSrc = !string.IsNullOrEmpty(ps.LogoFile) ? ps.HomeDirectory + ps.LogoFile : "";
    string homeUrl = Globals.NavigateURL(ps.HomeTabId);

    // Login / Logout
    string loginUrl = isAuth
        ? Globals.NavigateURL(ps.ActiveTab.TabID, "Logoff")
        : Globals.LoginURL(HttpContext.Current.Request.RawUrl, false);
    string loginText = isAuth ? "Logout" : "Login";

    // User profile
    string userName = isAuth ? user.DisplayName : "";
    string userUrl = isAuth ? Globals.UserProfileURL(user.UserID) : "";
}

@helper RenderNodes(dynamic nodes, bool isRoot) {
    <ul class="@(isRoot ? "w-full flex lg:flex-row flex-col gap-2" : "py-1 list-none m-0")">
        @foreach (var node in nodes)
        {
            bool hasChildren = node.HasChildren();
            string target = !string.IsNullOrEmpty((string)node.Target) ? ("target=\"" + node.Target + "\"") : "";
            string href = (bool)node.Enabled ? (string)node.Url : "javascript:void(0);";
            bool selected = (bool)node.Selected;

            <li class="relative @(hasChildren ? "[&:hover>.submenu]:visible [&:hover>.submenu]:opacity-100" : "")">
                @if (isRoot)
                {
                    if ((bool)node.Enabled)
                    {
                        <a href="@href" @target class="inline-flex items-center px-4 py-2 font-bold uppercase tracking-wide text-white! rounded-md no-underline! transition-colors duration-150 hover:bg-white/15 @(selected ? "bg-white/15" : "")">
                            @node.Text
                            @if (hasChildren)
                            {
                                <svg class="ml-1 h-4 w-4 text-white/50" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                                </svg>
                            }
                        </a>
                    }
                    else
                    {
                        <span class="inline-flex items-center px-4 py-2 font-bold uppercase tracking-wide text-white/40 cursor-default">
                            @node.Text
                        </span>
                    }
                }
                else
                {
                    if ((bool)node.Enabled)
                    {
                        <a href="@href" @target class="flex items-center justify-between px-4 py-2 text-gray-700 no-underline transition-colors duration-150 hover:bg-gray-50 hover:text-cyan-700 @(selected ? "!text-cyan-700 !font-medium !bg-gray-50" : "")">
                            @node.Text
                            @if (hasChildren)
                            {
                                <svg class="ml-1 h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                            }
                        </a>
                    }
                    else
                    {
                        <span class="block px-4 py-2 text-gray-400 cursor-default @(selected ? "!text-cyan-700 !font-medium" : "")">
                            @node.Text
                        </span>
                    }
                }
                @if (hasChildren)
                {
                    <div class="submenu invisible opacity-0 absolute z-50 @(isRoot ? "left-0 top-full" : "left-full top-0") w-56 rounded-md bg-white shadow-lg ring-1 ring-black/5 transition-all duration-150 ease-in-out">
                        @RenderNodes(node.Children, false)
                    </div>
                }
            </li>
        }
    </ul>
}

<header class="sticky top-0 z-50">
    <!-- Top Bar: User/Login -->
    <div class="hidden lg:block bg-slate-800 text-white">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-10 items-center justify-end gap-4 text-sm">
                <a href="@loginUrl" class="text-white hover:text-cyan-300 transition-colors font-medium">@loginText</a>
                @if (isAuth)
                {
                    <a href="@userUrl" class="text-cyan-300 hover:text-white transition-colors">@userName</a>
                }
            </div>
        </div>
    </div>

    <!-- Main Header: Logo + Nav -->
    <div class="bg-slate-700">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-20 items-center justify-between">

                <!-- Logo -->
                <div class="flex shrink-0 items-center">
                    @if (!string.IsNullOrEmpty(logoSrc))
                    {
                        <a href="@homeUrl"><img src="@logoSrc" alt="@ps.PortalName" class="h-12 w-auto" /></a>
                    }
                </div>

                <!-- Desktop Navigation -->
                <nav class="hidden lg:flex lg:items-center lg:gap-2" aria-label="Main Navigation">
                    @RenderNodes(Model.Source.root.Children, true)
                </nav>

                <!-- Mobile Menu Button -->
                <button type="button"
                        class="hamburger lg:hidden"
                        aria-expanded="false"
                        aria-label="Toggle navigation"
                        onclick="this.classList.toggle('open'); var m=document.getElementById('mobile-menu'); m.classList.toggle('open'); this.setAttribute('aria-expanded', m.classList.contains('open'));">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div id="mobile-menu" class="lg:hidden bg-slate-700">
        <div class="flex lg:hidden p-4">
            @RenderNodes(Model.Source.root.Children, true)
        </div>
        <div class="lg:hidden border-t border-white/10 px-4 py-3">
            <div class="flex items-center gap-3 text-sm">
                @if (isAuth)
                {
                    <a href="@userUrl" class="text-white/70">@userName</a>
                }
                <a href="@loginUrl" class="text-cyan-300 text-xs font-medium">@loginText</a>
            </div>
        </div>
    </div>
</header>

<script>
(function(){
    var mql = window.matchMedia('(min-width: 1024px)');
    function closeMobile(){
        if(!mql.matches) return;
        var btn = document.querySelector('.hamburger');
        var menu = document.getElementById('mobile-menu');
        if(btn) { btn.classList.remove('open'); btn.setAttribute('aria-expanded','false'); }
        if(menu) menu.classList.remove('open');
    }
    mql.addEventListener('change', closeMobile);
})();
</script>
