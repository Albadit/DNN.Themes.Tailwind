@using DotNetNuke.Web.DDRMenu;
@using System.Dynamic;
@using DotNetNuke.Common;
@using DotNetNuke.Entities.Portals;
@inherits DotNetNuke.Web.Razor.DotNetNukeWebPage<dynamic>

@{
    var ps = PortalSettings.Current;

    // Logo
    string logoSrc = !string.IsNullOrEmpty(ps.LogoFile) ? ps.HomeDirectory + ps.LogoFile : "";
    string homeUrl = Globals.NavigateURL(ps.HomeTabId);

    // Copyright
    string copyright = string.Format("Copyright {0} by {1}", DateTime.Now.Year, ps.PortalName);

    // Terms & Privacy
    string termsUrl = ps.TermsTabId > -1 ? Globals.NavigateURL(ps.TermsTabId) : "#";
    string privacyUrl = ps.PrivacyTabId > -1 ? Globals.NavigateURL(ps.PrivacyTabId) : "#";
}

<footer class="footer-section bg-gray-900 text-gray-300 text-sm leading-relaxed">
    <!-- Accent Bar -->
    <div class="h-1 bg-linear-to-r from-slate-600 to-cyan-700"></div>

    <!-- Footer Content -->
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">

            <!-- Left: Nav Links -->
            <div class="flex flex-col gap-4">
                <nav>
                    <ul class="flex flex-wrap max-sm:flex-col gap-2 items-start">
                        @foreach (var node in Model.Source.root.Children)
                        {
                            var attrTarget = !string.IsNullOrEmpty(node.Target) ? ("target=\"" + node.Target + "\"") : string.Empty;
                            var attrHref = node.Enabled ? node.Url : "javascript:void(0);";

                            <li class="flex">
                                @if (node.Enabled)
                                {
                                    <a href="@attrHref" @attrTarget class="px-4 py-2 text-white/80 no-underline transition-colors duration-150 hover:text-white hover:bg-white/10 hover:rounded-[0.375rem] hover:no-underline @(node.Selected ? "text-white!" : "")">
                                        @node.Text
                                    </a>
                                }
                                else
                                {
                                    <span class="px-4 py-2 text-white/30 cursor-default">
                                        @node.Text
                                    </span>
                                }
                            </li>
                        }
                    </ul>
                </nav>

                <!-- Terms / Privacy -->
                <div class="flex flex-wrap items-center gap-2 text-sm text-gray-300">
                    <a href="@termsUrl" class="text-gray-300 no-underline transition-colors duration-150 hover:text-white">Terms</a>
                    <span class="text-white/30">|</span>
                    <a href="@privacyUrl" class="text-gray-300 no-underline transition-colors duration-150 hover:text-white">Privacy</a>
                </div>

                <!-- Copyright -->
                <div class="text-sm text-gray-300">
                    @copyright
                </div>
            </div>

            <!-- Right: Logo watermark -->
            <div class="hidden lg:block">
                @if (!string.IsNullOrEmpty(logoSrc))
                {
                    <a href="@homeUrl"><img src="@logoSrc" alt="@ps.PortalName" class="h-32 w-auto opacity-30" /></a>
                }
            </div>
        </div>
    </div>
</footer>
